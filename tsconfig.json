{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "declaration": true,
        "rewriteRelativeImportExtensions": true
    },
    "include": ["src/**/*", "prisma.config.ts", "generated/**/*"],
    "exclude": ["node_modules", "dist"]
}
